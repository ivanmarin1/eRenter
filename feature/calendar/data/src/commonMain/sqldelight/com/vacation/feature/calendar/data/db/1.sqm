-- Schema v1 -> v2: add payment, notes and guest-detail columns to existing bookings.
-- Text columns default to '' and payments are nullable, so rows created before this
-- migration keep working with sensible empty/unset values.
ALTER TABLE bookingEntity ADD COLUMN upfrontPayment REAL;
ALTER TABLE bookingEntity ADD COLUMN restPayment REAL;
ALTER TABLE bookingEntity ADD COLUMN notes TEXT NOT NULL DEFAULT '';
ALTER TABLE bookingEntity ADD COLUMN contactInfo TEXT NOT NULL DEFAULT '';
ALTER TABLE bookingEntity ADD COLUMN country TEXT NOT NULL DEFAULT '';
